rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read on validation collection used to test connection
    match /test/{document=**} {
      allow read: if true;
    }
    
    // Core custom security validation functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (request.auth.token.email == 'admin@kasirpintar.com' || request.auth.token.email == 'adminkursus@gmail.com');
    }

    // Rules for usernames unique mapping
    match /usernames/{username} {
      // Anyone can check if a username exists, lookup email, or list/query to find accounts by email
      allow read: if true;
      
      // Can register a username mapping if authenticated
      allow create: if true;
                     
      // Only the owner of the username map or admin can update/delete it
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Rules for User Profile & Subcollections
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /products/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /transactions/{transactionId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /debts/{debtId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /expenses/{expenseId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Rules for superadmin global configuration
    match /config/{configId} {
      allow read: if true; // Let any guest view support hotline contacts
      allow write: if isAdmin();
    }

    // Rules for registered users management catalog (licensing & status bounds)
    match /registered_users/{targetUserId} {
      allow read: if true; // Allow guest lookup to verify users/passwords prior to Auth session if necessary
      allow create: if true; // Any store can register their license details
      allow update: if isAuthenticated() && (request.auth.uid == targetUserId || isAdmin()); // Shop owners can update their fields, admins have full privileges
      allow delete: if isAdmin(); // Only superadmins can delete entire registries
    }

    // Rules for User Feedback and Suggestions
    match /feedback/{feedbackId} {
      allow read, update, delete: if isAdmin();
      allow create: if true; // Perfect for frictionless bug reports / recommendations
    }

    // Rules for Quick Polls (Polling Cepat)
    match /polls/{pollId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for Quick Poll Responses
    match /poll_responses/{responseId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
